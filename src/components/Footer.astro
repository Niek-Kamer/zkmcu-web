---
// Custom Footer override. Renders Starlight's default Footer (EditLink,
// LastUpdated, Pagination) first so built-in nav behaviour is preserved,
// then appends a project-wide docs-style footer: brand + link columns +
// legal line. Wired via `components.Footer` in astro.config.mjs.
import Default from '@astrojs/starlight/components/Footer.astro';

const year = new Date().getFullYear();
const repo = 'https://github.com/Niek-Kamer/zkmcu';
const author = 'https://github.com/Niek-Kamer';
---

<Default><slot /></Default>

<footer class="site-footer" role="contentinfo">
	<div class="site-footer__top">
		<div class="site-footer__brand">
			<div class="site-footer__title">zkmcu</div>
			<div class="site-footer__sub">
				no_std SNARK and STARK verifiers for microcontrollers. BN254,
				BLS12-381, and winterfell STARK, all under 128 KB SRAM.
			</div>
		</div>

		<nav class="site-footer__cols" aria-label="Site footer">
			<div class="site-footer__col">
				<div class="site-footer__heading">Project</div>
				<ul>
					<li><a href={repo}>Source on GitHub</a></li>
					<li><a href={`${repo}/issues`}>Issues</a></li>
					<li><a href={`${repo}/blob/main/LICENSE-MIT`}>License (MIT OR Apache-2.0)</a></li>
				</ul>
			</div>
			<div class="site-footer__col">
				<div class="site-footer__heading">Author</div>
				<ul>
					<li><a href={author}>@Niek-Kamer</a></li>
					<li><a href={`${repo}/blob/main/README.md`}>About zkmcu</a></li>
				</ul>
			</div>
		</nav>
	</div>

	<div class="site-footer__legal">
		<span>© {year} @Niek-Kamer</span>
		<span aria-hidden="true" class="site-footer__dot">·</span>
		<span><a href="https://www.kvk.nl/bestellen/#/99972263000065008537?origin=search" rel="noopener" target="_blank">KVK 99972263</a></span>
		<span aria-hidden="true" class="site-footer__dot">·</span>
		<span>Built with <a href="https://astro.build">Astro</a> + <a href="https://starlight.astro.build">Starlight</a></span>
	</div>
</footer>

<script>
	// Opt-out via prefers-reduced-motion is handled by CSS, we still set
	// the vars harmlessly for users who have it on because the masked dot
	// layer is display:none for them anyway.
	//
	// Selector matches the current hero-stat plus any future anchor-wrapped
	// cards or explicitly-tagged .interactive-card. Keep the selector list
	// in sync with the CSS block that reads --mx / --my.
	const selector = '.hero-stat, a.card, a.sl-link-card, .interactive-card';
	const targets = document.querySelectorAll<HTMLElement>(selector);
	for (const card of targets) {
		card.addEventListener('pointermove', (event) => {
			const rect = card.getBoundingClientRect();
			const x = ((event.clientX - rect.left) / rect.width) * 100;
			const y = ((event.clientY - rect.top) / rect.height) * 100;
			card.style.setProperty('--mx', `${x}%`);
			card.style.setProperty('--my', `${y}%`);
		});
	}
</script>
