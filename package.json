		"@fontsource/jetbrains-mono": "^5.2.8",
		"astro": "^6.0.1",
		"sharp": "^0.34.2",
		"smol-toml": "^1.6.1"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.8",
		"@biomejs/biome": "^2.4.13",
		"@eslint/js": "^10.0.1",
		"astro-eslint-parser": "^1.4.0",
		"eslint": "^10.2.1",
		"eslint-plugin-astro": "^1.7.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"globals": "^17.5.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0"
	}
