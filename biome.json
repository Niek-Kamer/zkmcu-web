{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!dist",
			"!.astro",
			"!node_modules",
			"!bun.lock",
			"!public",
			"!zkmcu",
			"!**/*.astro",
			"!**/*.mdx",
			"!**/*.md"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 80,
		"lineEnding": "lf"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all",
			"arrowParentheses": "always",
			"bracketSpacing": true
		}
	},
	"json": {
		"formatter": {
			"indentStyle": "tab",
			"trailingCommas": "none"
		},
		"parser": {
			"allowComments": true,
			"allowTrailingCommas": false
		}
	},
	"css": {
		"formatter": {
			"enabled": true,
			"indentStyle": "tab",
			"quoteStyle": "single"
		},
		"linter": {
			"enabled": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": { "recommended": true },
			"complexity": {
				"recommended": true,
				"noExcessiveCognitiveComplexity": {
					"level": "error",
					"options": { "maxAllowedComplexity": 15 }
				},
				"noForEach": "off"
			},
			"correctness": {
				"recommended": true,
				"useExhaustiveDependencies": "error",
				"noUndeclaredDependencies": "off",
				"noUnusedImports": "error",
				"noUnusedVariables": "error",
				"noUnusedFunctionParameters": "error",
				"noUnusedPrivateClassMembers": "error"
			},
			"performance": { "recommended": true },
			"security": { "recommended": true },
			"style": {
				"recommended": true,
				"noDefaultExport": "off",
				"useNamingConvention": "off",
				"useFilenamingConvention": "off",
				"useBlockStatements": "error",
				"useShorthandAssign": "error",
				"useConsistentArrayType": {
					"level": "error",
					"options": { "syntax": "shorthand" }
				},
				"noNonNullAssertion": "error"
			},
			"suspicious": {
				"recommended": true,
				"noConsole": {
					"level": "error",
					"options": { "allow": ["warn", "error"] }
				},
				"noExplicitAny": "error",
				"useAwait": "error"
			},
			"nursery": { "recommended": false }
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on",
				"useSortedKeys": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.json"],
			"formatter": { "indentStyle": "tab" }
		}
	]
}
